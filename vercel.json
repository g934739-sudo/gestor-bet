{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/login", "dest": "/login.html" },
    { "src": "/app", "dest": "/app.html" },
    { "src": "/privacidade", "dest": "/privacidade.html" },
    { "src": "/termos", "dest": "/termos.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
